Experiment 10: Jenkins Pipeline Visualization and Logs
Tasks: View pipeline stages, analyze logs, debug failures.
Outcome: CI troubleshooting skills.



pipeline {
    agent any

    stages {

        stage('Clone') {
            steps {
                echo "Cloning GitHub repository..."
                git branch: 'main',
                    url: 'https://github.com/RakshithaMeleyyanavar/Bank_service.git'
            }
        }

        stage('Workspace Check') {
            steps {
                echo "Checking workspace files..."
                bat 'dir'
            }
        }

        stage('Compile') {
            steps {
                echo "Compiling all Java files..."
                bat 'javac *.java'
            }
        }

        stage('Run') {
            steps {
                echo "Running Java program..."
                bat 'java BankService'
            }
        }
    }

    post {
        success {
            echo "Pipeline SUCCESS ✅ All stages completed"
        }
        failure {
            echo "Pipeline FAILED ❌ Check file name, branch, or Java errors"
        }
    }
}
