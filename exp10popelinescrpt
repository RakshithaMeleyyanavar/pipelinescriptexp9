Experiment 10: Jenkins Pipeline Visualization and Logs
Tasks: View pipeline stages, analyze logs, debug failures.
Outcome: CI troubleshooting skills.



pipeline {
    agent any

    stages {

        stage('Clone') {
            steps {
                echo "Cloning GitHub repository..."
                git 'https://github.com/RakshithaMeleyyanavar/Bank_service.git'
            }
        }

        stage('Workspace Check') {
            steps {
                echo "Checking files in workspace..."
                bat 'dir'
            }
        }

        stage('Build') {
            steps {
                echo "Compiling Java program..."
                bat "javac BankService.java"
            }
        }

        stage('Run') {
            steps {
                echo "Executing Java program..."
                bat "java BankService"
            }
        }
    }

    post {
        success {
            echo "Pipeline executed successfully "
        }
        failure {
            echo "Pipeline failed Check logs for errors"
        }
    }
}
